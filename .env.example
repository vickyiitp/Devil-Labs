# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# --- FREE & OPEN SOURCE DISPATCHER CONFIGURATIONS ---

# 1. Nodemailer SMTP (Email)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
ADMIN_EMAIL="devil.labs.contact@gmail.com"

# 2. Telegram Bot (Free & Open Source Bot API notifications)
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

# 3. WhatsApp Integration (Self-hosted WhatsApp API, Baileys, Evolution API, etc.)
WHATSAPP_API_URL=""
WHATSAPP_API_TOKEN=""
WHATSAPP_RECIPIENT_PHONE=""

# 4. SMS Custom HTTP Gateway (Universal Gateway Adapter)
SMS_GATEWAY_URL="" # e.g. https://api.gateway.com/send?to={to}&msg={message}
SMS_GATEWAY_TOKEN=""
SMS_RECIPIENT_PHONE=""

# 5. Twilio Fallback Gateways (Optional SMS/WhatsApp Backup)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_SMS=""
TWILIO_TO_SMS=""
TWILIO_WHATSAPP_FROM=""
TWILIO_WHATSAPP_TO=""

